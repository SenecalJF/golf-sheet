# Copy to .env.local and fill in.

# Required — any Postgres connection string.
# For Vercel Postgres / Neon, run `vercel env pull .env.local` and this is set for you.
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Required — auth/session configuration.
BETTER_AUTH_SECRET="replace-with-a-long-random-string"
BETTER_AUTH_URL="http://localhost:3000"
SIGNUP_INVITE_CODE="replace-with-private-invite-code"
INITIAL_ADMIN_EMAIL="you@example.com"

# Required — 32 random bytes encoded as base64.
# Example: openssl rand -base64 32
USER_SECRET_ENCRYPTION_KEY="replace-with-32-byte-base64-key"

# Claude keys are now entered per user in Settings and stored encrypted.
