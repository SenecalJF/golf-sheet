# Copy to .env.local and fill in.

# Required — any Postgres connection string.
# For Vercel Postgres / Neon, run `vercel env pull .env.local` and this is set for you.
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Optional — enables AI scorecard OCR and AI insights.
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY="sk-ant-..."
