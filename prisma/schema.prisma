generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Course {
  id        String   @id @default(cuid())
  name      String   @unique
  city      String
  province  String   @default("QC")
  country   String   @default("Canada")
  notes     String?
  createdAt DateTime @default(now())

  tees   Tee[]
  rounds Round[]
}

model Tee {
  id        String  @id @default(cuid())
  courseId  String
  name      String
  color     String?
  rating    Float?
  slope     Int?
  yardage   Int?
  pars      String
  holeCount Int     @default(18)

  rating9F Float?
  slope9F  Int?
  rating9B Float?
  slope9B  Int?

  course Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  rounds Round[]

  @@unique([courseId, name])
}

model User {
  id            String       @id @default(cuid())
  name          String
  email         String       @unique
  emailVerified Boolean      @default(false)
  image         String?
  isAdmin       Boolean      @default(false)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  sessions Session[]
  accounts Account[]
  rounds   Round[]
  secrets  UserSecret[]

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verification")
}

model UserSecret {
  id         String   @id @default(cuid())
  userId     String
  provider   String
  ciphertext String
  iv         String
  authTag    String
  keyLast4   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId])
}

model Round {
  id              String   @id @default(cuid())
  userId          String?
  courseId        String
  teeId           String?
  date            DateTime
  holeCount       Int
  nineType        String?
  notes           String?
  weather         String?
  pcc             Float    @default(0)
  totalStrokes    Int
  totalPar        Int
  scoreDiff       Float?
  sourceImage     String?
  extractionModel String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user   User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  course Course      @relation(fields: [courseId], references: [id])
  tee    Tee?        @relation(fields: [teeId], references: [id])
  holes  HoleScore[]

  @@index([date])
  @@index([userId])
  @@index([userId, date])
  @@index([courseId])
}

model HoleScore {
  id         String  @id @default(cuid())
  roundId    String
  holeNumber Int
  par        Int
  strokes    Int
  putts      Int?
  fairwayHit Boolean?
  gir        Boolean?
  confidence Float?
  illegible  Boolean @default(false)

  round Round @relation(fields: [roundId], references: [id], onDelete: Cascade)

  @@unique([roundId, holeNumber])
}
